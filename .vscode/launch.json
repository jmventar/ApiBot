{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "dry run JSON single",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/src/main.py",
      "console": "integratedTerminal",
      "justMyCode": true,
      "args": [
        "--clean",
        "-f",
        "${workspaceFolder}/test/data/single_replace.json"
      ]
    },
    {
      "name": "dry run JSON_ARRAY single",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/src/main.py",
      "console": "integratedTerminal",
      "justMyCode": true,
      "args": [
        "--clean",
        "-f",
        "${workspaceFolder}/test/data/json_arrays.json"
      ]
    },
    {
      "name": "CSV single",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/src/main.py",
      "console": "integratedTerminal",
      "justMyCode": true,
      "args": [
        "-f",
        "${workspaceFolder}/test/data/single_replace.csv",
        "-u",
        "https://jsonplaceholder.typicode.com/posts/{{post_num}}",
        "-s",
        "csv"
      ]
    },
    {
      "name": "CSV multiple",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/src/main.py",
      "console": "integratedTerminal",
      "justMyCode": true,
      "args": [
        "-f",
        "${workspaceFolder}/test/data/multiple_replace.csv",
        "-u",
        "https://jsonplaceholder.typicode.com/posts/1?param1={{replace_1}}&param2={{replace_2}}&param3={{replace_3}}",
        "-s",
        "csv"
      ]
    },
    {
      "name": "JSON_ARRAY",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/src/main.py",
      "console": "integratedTerminal",
      "justMyCode": true,
      "args": [
        "-s",
        "json_array",
        "--clean",
        "-f",
        "${workspaceFolder}/test/data/json_arrays.json",
        "-u",
        "https://jsonplaceholder.typicode.com/posts/{{0}}"
      ]
    },
       {
      "name": "JSON single",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/src/main.py",
      "console": "integratedTerminal",
      "justMyCode": true,
      "args": [
        "--clean",
        "-f",
        "${workspaceFolder}/test/data/single_replace.json",
        "-m",
        "POST",
        "-u",
        "https://jsonplaceholder.typicode.com/posts/1?name={{test}}",
        "-t",
        "123456",
        "-d",
        "2.5"
      ]
    },
    {
      "name": "JSON multiple",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/src/main.py",
      "console": "integratedTerminal",
      "justMyCode": true,
      "args": [
        "-f",
        "${workspaceFolder}/test/data/multiple_replace.json",
        "-m",
        "POST",
        "-u",
        "https://jsonplaceholder.typicode.com/posts/1?param1={{id}}&param2={{name}}&param3={{map_id}}&param4={{map}}",
        "-t",
        "123456",
        "-d",
        "2.5"
      ]
    },
  ]
}
